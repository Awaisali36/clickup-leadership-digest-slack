      "name": "Data from lists"
    },
    {
      "parameters": {
        "jsCode": "// Get input\nconst input = $input.first().json;\nconst totalItems = input.totalitems || [];\n\n// Final accumulators\nlet completed = [];\nlet atRisk = [];\nlet onTrack = [];\n\nlet completedCount = 0;\nlet atRiskCount = 0;\nlet onTrackCount = 0;\n\n// Loop through each item\ntotalItems.forEach(item => {\n    completedCount += item.completedCount || 0;\n    atRiskCount += item.atRiskCount || 0;\n    onTrackCount += item.onTrackCount || 0;\n\n    completed.push(...(item.completedProjects || []));\n    atRisk.push(...(item.atRiskProjects || []));\n    onTrack.push(...(item.onTrack || []));\n});\n\n// Optional: remove duplicates by URL (recommended)\nconst dedupeByUrl = arr =>\n    Array.from(new Map(arr.map(o => [o.url, o])).values());\n\ncompleted = dedupeByUrl(completed);\natRisk = dedupeByUrl(atRisk);\nonTrack = dedupeByUrl(onTrack);\n\n// Return final result\nreturn [{\n    json: {\n        completedCount: completed.length,\n        atRiskCount: atRisk.length,\n        onTrackCount: onTrack.length,\n\n        completed,\n        atRisk,\n        onTrack\n    }\n}];\n"
      },
