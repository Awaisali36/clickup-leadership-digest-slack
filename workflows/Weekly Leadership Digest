      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst onTrack = [];\nconst atRisk = [];\nconst completed = [];\n\nfor (const item of items) {\n  const t = item.json;\n  const status = (t.status?.status || \"\").toLowerCase();\n\n  const entry = {\n    client: t.list?.name || \"Unknown\",\n    name: t.name,\n    status: t.status?.status || \"\",\n    url: t.url,\n  };\n\n  // Completed\n  if (status === \"signed & accepted\" || status === \"go-live phase\") {\n    completed.push(entry);\n  }\n  // Needs attention\n  else if (status === \"waiting on client\") {\n    atRisk.push(entry);\n  }\n  // Everything else\n  else {\n    onTrack.push(entry);\n  }\n}\n\nreturn [{\n  json: {\n    onTrackCount: onTrack.length,\n    atRiskCount: atRisk.length,\n    completedCount: completed.length,\n    atRiskProjects: atRisk,\n    completedProjects: completed.slice(0, 5),\n    onTrack: onTrack.slice(0, 5),\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
